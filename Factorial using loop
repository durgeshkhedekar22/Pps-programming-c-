#include <stdio.h>

int main() {
    int num, i;
    long long factorial = 1;
    printf("Enter a number: ");
    scanf("%d", &num);

    for(i = 1; i <= num; i++) {
        factorial = factorial * i;
    }
    printf("Factorial = %lld", factorial);

    return 0;
}
